<script>
// ── FIT name to full viewport width ──────────────────
(function(){
  var el = document.getElementById('hero-name');
  if(!el) return;
  function fit(){
    var cs    = getComputedStyle(el);
    var padL  = parseFloat(cs.paddingLeft)  || 0;
    var padR  = parseFloat(cs.paddingRight) || 0;
    var avail = window.innerWidth - padL - padR;
    var probe = document.createElement('span');
    probe.textContent = el.textContent;
    probe.style.cssText =
      'position:fixed;top:-9999px;left:-9999px;' +
      'visibility:hidden;white-space:nowrap;display:inline-block;' +
      'font-size:100px;' +
      'font-family:'    + cs.fontFamily    + ';' +
      'font-weight:'    + cs.fontWeight    + ';' +
      'letter-spacing:' + cs.letterSpacing + ';';
    document.body.appendChild(probe);
    var w = probe.getBoundingClientRect().width;
    document.body.removeChild(probe);
    if(w > 0) el.style.fontSize = (avail / w * 100 * 0.96) + 'px';
  }
  if(document.fonts && document.fonts.ready){
    document.fonts.ready.then(fit);
  } else {
    fit();
  }
  window.addEventListener('resize', fit, {passive:true});
})();

// ── MANIFESTO: letter by letter ───────────────────────
(function(){
  const words=[
    {t:'Ever'},{t:'Since'},{t:'I'},{t:'Was'},{t:'Young'},{t:'I'},{t:'Wanted'},{t:'To'},{t:'Transform'},
    {t:'Unstructured',a:true},{t:'Data',a:true},
    {t:'Into'},{t:'Actionable'},{t:'Business'},{t:'Insights'}
  ];
  const h1=document.getElementById('hl'); if(!h1) return;
  let d=0; const step=0.016;
  words.forEach((w,wi)=>{
    const wrap=document.createElement('span'); wrap.style.display='inline-block';
    if(w.a) wrap.style.color='var(--blue)';
    [...w.t].forEach(ch=>{
      const s=document.createElement('span'); s.className='ch';
      s.textContent=ch; s.style.animationDelay=d+'s'; d+=step; wrap.appendChild(s);
    });
    h1.appendChild(wrap);
    if(wi<words.length-1) h1.appendChild(document.createTextNode('\u00A0'));
  });
  const dot=document.createElement('span'); dot.className='dot';
  dot.textContent='.'; dot.style.animationDelay=(d+.25)+'s'; h1.appendChild(dot);
})();



// ── REVEAL on scroll ─────────────────────────────────
const io=new IntersectionObserver(es=>{
  es.forEach(e=>{ if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);} });
},{threshold:.1});
document.querySelectorAll('.rev').forEach(el=>io.observe(el));

// ── CASE STUDIES accordion ───────────────────────────
document.querySelectorAll('.case').forEach((cas)=>{
  const head=cas.querySelector('.case-head');
  const wrap=cas.querySelector('.case-body-wrap');
  const icon=cas.querySelector('.case-icon');
  if(!head||!wrap) return;
  head.addEventListener('click',()=>{
    const isOpen=wrap.classList.toggle('open');
    if(icon) icon.textContent=isOpen?'—':'+';
    head.setAttribute('aria-expanded', isOpen);
  });
  head.addEventListener('keydown',e=>{
    if(e.key==='Enter'||e.key===' '){ e.preventDefault(); head.click(); }
  });
});

// ── QUIZ ──────────────────────────────────────────────
document.querySelectorAll('.quiz').forEach(q=>{
  const correct=q.dataset.correct;
  const opts=q.querySelectorAll('.q-opt');
  const toast=q.querySelector('.q-toast');
  const impact=q.nextElementSibling;
  let done=false;
  opts.forEach(opt=>{
    opt.addEventListener('click',()=>{
      if(done) return; done=true;
      const ok=opt.dataset.v===correct;
      opts.forEach(o=>{
        o.setAttribute('disabled','');
        if(o===opt) o.classList.add('selected');
        else o.classList.add('faded');
        if(o.dataset.v===correct) o.classList.add('correct');
      });
      toast.querySelector('.q-title').textContent=ok?'Racja!':'Pudło!';
      toast.querySelector('.q-sub').textContent=ok
        ?'Wariant '+correct+' rzeczywiście wygrał test.'
        :'Wygrał wariant '+correct+' — ale to dobra okazja, żeby zobaczyć dlaczego.';
      toast.classList.add(ok?'ok':'err');
      requestAnimationFrame(()=>toast.classList.add('show'));
      if(impact) setTimeout(()=>impact.classList.add('show'),650);
    });
  });
});

// ── SKILLS TAB ────────────────────────────────────────
(function(){
  var head = document.getElementById('skills-toggle');
  var body = document.getElementById('skills-body');
  var icon = document.getElementById('skills-icon');
  if(!head || !body) return;
  head.addEventListener('click', function(){
    var open = body.classList.toggle('open');
    icon.textContent = open ? '—' : '+';
  });
})();

// ── SKILLS BAD TAB ────────────────────────────────────
(function(){
  var head = document.getElementById('skills-bad-toggle');
  var body = document.getElementById('skills-bad-body');
  var icon = document.getElementById('skills-bad-icon');
  if(!head || !body) return;
  head.addEventListener('click', function(){
    var open = body.classList.toggle('open');
    icon.textContent = open ? '—' : '+';
  });
})();
</script>
</body>
</html>
